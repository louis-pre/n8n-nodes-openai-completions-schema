{
	"compilerOptions": {
		"strict": true,
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "es2019",
		"lib": ["es2019", "es2020"],
		"removeComments": false,
		"sourceMap": true,
		"strictNullChecks": true,
		"useUnknownInCatchVariables": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"outDir": "./dist/",
		"declaration": true,
		"resolveJsonModule": true
	},
	"include": [
		"nodes/**/*",
		"credentials/**/*",
		"nodes/LmChatOpenAiCompletionsSchema/**/*"
	],
	"exclude": [
		"**/*.test.ts",
		"node_modules",
		"dist"
	]
}
